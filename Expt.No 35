#include <stdio.h>

int main()
{
    int n, i, blockNo;

    printf("Enter number of file blocks: ");
    scanf("%d", &n);

    int indexBlock[n];

    printf("Enter block numbers:\n");
    for(i = 0; i < n; i++)
    {
        scanf("%d", &indexBlock[i]);
    }

    printf("\nIndexed File Allocation Table\n");
    printf("Index\tBlock Number\n");

    for(i = 0; i < n; i++)
    {
        printf("%d\t%d\n", i, indexBlock[i]);
    }

    printf("\nEnter block index to access: ");
    scanf("%d", &blockNo);

    if(blockNo >= 0 && blockNo < n)
    {
        printf("Block at index %d is stored at disk block %d\n",
               blockNo, indexBlock[blockNo]);
    }
    else
    {
        printf("Invalid Index!\n");
    }

    return 0;
}
