#include <stdio.h>

int main()
{
    int pages[20], frames[10];
    int n, f, i, j, k = 0;
    int faults = 0, found;

    printf("Number of pages: ");
    scanf("%d",&n);

    printf("Reference string: ");
    for(i=0;i<n;i++)
        scanf("%d",&pages[i]);

    printf("Frames: ");
    scanf("%d",&f);

    for(i=0;i<f;i++)
        frames[i] = -1;

    for(i=0;i<n;i++)
    {
        found = 0;

        for(j=0;j<f;j++)
        {
            if(frames[j] == pages[i])
            {
                found = 1;
                break;
            }
        }

        if(!found)
        {
            frames[k] = pages[i];
            k = (k + 1) % f;
            faults++;
        }
    }

    printf("Page Faults = %d\n", faults);

    return 0;
}
