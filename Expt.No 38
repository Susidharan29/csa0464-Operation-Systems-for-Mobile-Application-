#include <stdio.h>
#include <stdlib.h>

void sort(int arr[], int n)
{
    int i, j, temp;

    for(i = 0; i < n - 1; i++)
    {
        for(j = 0; j < n - i - 1; j++)
        {
            if(arr[j] > arr[j + 1])
            {
                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}

int main()
{
    int req[100], n, head, disk_size;
    int i, pos;
    int seek = 0;

    printf("Enter number of requests: ");
    scanf("%d", &n);

    printf("Enter request queue:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &req[i]);

    printf("Enter initial head position: ");
    scanf("%d", &head);

    printf("Enter disk size: ");
    scanf("%d", &disk_size);

    sort(req, n);

    for(i = 0; i < n; i++)
    {
        if(req[i] >= head)
        {
            pos = i;
            break;
        }
    }

    printf("\nSeek Sequence:\n%d", head);

    /* Move right */
    for(i = pos; i < n; i++)
    {
        seek += abs(req[i] - head);
        head = req[i];
        printf(" -> %d", head);
    }

    /* Go to end of disk */
    seek += abs((disk_size - 1) - head);
    head = disk_size - 1;
    printf(" -> %d", head);

    /* Reverse direction */
    for(i = pos - 1; i >= 0; i--)
    {
        seek += abs(req[i] - head);
        head = req[i];
        printf(" -> %d", head);
    }

    printf("\n\nTotal Seek Time = %d\n", seek);

    return 0;
}
