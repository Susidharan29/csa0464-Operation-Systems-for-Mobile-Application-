#include <stdio.h>

int main()
{
    int pages[50], frames[10], time[10];
    int n, f, faults = 0;
    int i, j, pos, least, found, counter = 0;

    printf("Number of pages: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&pages[i]);

    printf("Frames: ");
    scanf("%d",&f);

    for(i=0;i<f;i++)
    {
        frames[i] = -1;
        time[i] = 0;
    }

    for(i=0;i<n;i++)
    {
        found = 0;

        for(j=0;j<f;j++)
        {
            if(frames[j] == pages[i])
            {
                counter++;
                time[j] = counter;
                found = 1;
            }
        }

        if(!found)
        {
            least = time[0];
            pos = 0;

            for(j=1;j<f;j++)
            {
                if(time[j] < least)
                {
                    least = time[j];
                    pos = j;
                }
            }

            counter++;
            frames[pos] = pages[i];
            time[pos] = counter;
            faults++;
        }
    }

    printf("Page Faults = %d\n", faults);

    return 0;
}
